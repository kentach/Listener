
<div class="audio-player">
  <!-- ===== 進捗バー ===== -->
  <div class="audio-progress-area">
    <span id="currentTime" class="time-text">
      0:00
    </span>

    <input
      type="range"
      id="progress"
      class="audio-progress"
      min="0"
      max="100"
      value="0"
    >
    <span id="duration" class="time-text">
      0:00
    </span>
  </div>

  <!-- ===== コントロール ===== -->
  <div class="audio-controls">
    <!-- 戻る -->
    <button class="audio-btn sub-btn" id="rewind3">
      <i class="bi bi-skip-backward-fill"></i>
    </button>

    <!-- 再生 -->
    <button class="audio-btn play-btn" id="playBtn">
      <i id="playIcon"
         class="bi bi-play-fill play-icon"></i>
    </button>

    <!-- 進む -->
    <button class="audio-btn sub-btn" id="forward3">
      <i class="bi bi-skip-forward-fill"></i>
    </button>

    <!-- ループ -->
    <button class="audio-btn loop-btn" id="loopBtn">
      <i class="bi bi-arrow-repeat"></i>
    </button>

    <!-- 再生速度 -->
    <select id="speedControl" class="speed-select">
      <% [0.7,0.8,0.9,1,1.1,1.2,1.3,1.4,1.5].each do |speed| %>
        <option value="<%= speed %>"
          <%= "selected" if speed == 1 %>>
          <%= speed %>x
        </option>
      <% end %>
    </select>

  </div>

  <!-- ===== audio ===== -->
  <audio id="audio" preload="metadata">
    <source
      src="/audio_files/"
      type="audio/mpeg">
  </audio>

</div>