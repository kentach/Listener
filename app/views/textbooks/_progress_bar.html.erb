<div class="learning-progress-container">
  <div class="learning-level">

    <div
      class="progress-circle"
      style="--progress: <%= @progress %>;"
    >
      <div class="progress-circle-inner">
        <span><%= @progress %>%</span>
      </div>
    </div>

    <div class="learning-info">
      <% if current_user.name.present? %>
        <h5><%= current_user.name %>さんの習得率</h5>
      <% else %>
        <h5>Userの習得率</h5>
      <% end %>

      <p>
        <% if @progress >= 80 %>
          素晴らしいです！この調子で続けましょう。
        <% elsif @progress >= 50 %>
          順調に成長しています。
        <% else %>
          毎日の積み重ねが大切です。
        <% end %>
      </p>
    </div>
  </div>
</div>